{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "es2015",
    "module": "esnext",
    "lib": ["es2017", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@chair-flight/chair-flight-components": [
        "libs/chair-flight-components/src/index.ts"
      ],
      "@chair-flight/chair-flight-question-bank-content": [
        "libs/chair-flight-question-bank-content/src/index.ts"
      ],
      "@chair-flight/chair-flight-question-bank-framework": [
        "libs/chair-flight-question-bank-framework/src/index.ts"
      ],
      "@chair-flight/js-utils": ["libs/js-utils/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
